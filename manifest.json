{
  "manifest_version": 3,
  "name": "Lumi",
  "version": "1.0",
  "description": "Lumi, tu asistente autónomo de navegación web.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "tabGroups",
    "downloads",
    "debugger"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "192": "icon128_ext.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/error-tracker.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false,
      "match_about_blank": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["js/dom-mapper.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_title": "Abrir Lumi",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "192": "icon128_ext.png"
    }
  },
  "sandbox": {
    "pages": ["ocr-sandbox.html"]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self' blob:; worker-src 'self' blob:;"
  }
}
